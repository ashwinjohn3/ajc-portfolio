---
interface Props {
  name: 'mail' | 'github' | 'linkedin'
  size?: number
}

const { name, size = 18 } = Astro.props
const common = {
  width: size,
  height: size,
  viewBox: '0 0 24 24',
  fill: 'none',
  stroke: 'currentColor',
  strokeWidth: '1.8',
  strokeLinecap: 'round',
  strokeLinejoin: 'round',
}
---

{name === 'mail' && (
  <svg {...common} aria-hidden="true">
    <path d="M4 6h16v12H4z"></path>
    <path d="m4 7 8 6 8-6"></path>
  </svg>
)}
{name === 'github' && (
  <svg {...common} aria-hidden="true">
    <path d="M9 19c-4 1.5-4-2-6-2"></path>
    <path d="M10 22v-3.5c-3-.7-6-2.2-6-6.1A4.8 4.8 0 0 1 5.2 9a4.4 4.4 0 0 1 .1-3.1s1-.3 3.2 1.2a11 11 0 0 1 5.9 0c2.2-1.5 3.2-1.2 3.2-1.2a4.4 4.4 0 0 1 .1 3.1 4.8 4.8 0 0 1 1.2 3.4c0 3.9-3 5.4-6 6.1V22"></path>
  </svg>
)}
{name === 'linkedin' && (
  <svg {...common} aria-hidden="true">
    <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-4 0v7h-4v-7a6 6 0 0 1 6-6z"></path>
    <path d="M2 9h4v12H2z"></path>
    <path d="M4 4h.01"></path>
  </svg>
)}
