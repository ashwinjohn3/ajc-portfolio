---
import { getCollection } from 'astro:content'
import BaseLayout from '../../layouts/BaseLayout.astro'
import PageSection from '../../components/PageSection.astro'
import { SITE_NAME } from '../../data/site'

await getCollection('photography')
---

<BaseLayout title={`Photography — ${SITE_NAME}`}>
  <PageSection label="photography" activePath="/photography">
    <p class="section-copy">
      Photo series live as Markdown-backed entries with remotely hosted images, so the gallery stays lightweight while each shoot can grow into its own page.
    </p>
    <p style="color: var(--ink-faint);">coming soon.</p>
  </PageSection>
</BaseLayout>
